# ─────────────────────────────────────────
# Edge-Safe Project — .gitignore
# ─────────────────────────────────────────

# ── Python virtual environment ──
venv/
.venv/
env/
ENV/
.env/

# ── Python cache ──
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.Python

# ── Python egg / build ──
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/

# ── SQLite database ──
# The database is generated by db_seed.py — never push it
backend/emergency.db
*.db
*.sqlite
*.sqlite3

# ── Environment / secrets ──
.env
.env.local
.env.production
*.env
secrets.py
config_local.py

# ── Ollama model files ──
# These are downloaded locally — too large for git
*.bin
*.gguf
*.ggml
models/

# ── Offline map tiles ──
# Downloaded by download_map_tiles.py — too large for git
backend/static/tiles/
*.png.tile

# ── Generated map HTML files ──
# These are auto-generated at runtime
backend/static/maps/

# ── Language packages (Argos Translate) ──
backend/language_packages/
*.argosmodel

# ── VS Code settings ──
.vscode/
*.code-workspace

# ── PyCharm / IntelliJ ──
.idea/
*.iml
*.iws

# ── macOS ──
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V*
.Trashes

# ── Windows ──
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Logs ──
*.log
logs/
pip-log.txt
pip-delete-this-directory.txt

# ── Testing / coverage ──
htmlcov/
.tox/
.coverage
.coverage.*
.cache
.pytest_cache/
nosetests.xml
coverage.xml
*.cover

# ── Jupyter Notebooks ──
.ipynb_checkpoints/

# ─────────────────────────────────────────
# Flutter / Dart
# ─────────────────────────────────────────

# Flutter build output
frontend/build/
frontend/.dart_tool/
frontend/.flutter-plugins
frontend/.flutter-plugins-dependencies
frontend/.packages

# Dart generated files
*.g.dart
*.freezed.dart
*.mocks.dart

# Flutter cache
frontend/.pub-cache/
frontend/.pub/

# Android build artifacts
frontend/android/.gradle/
frontend/android/local.properties
frontend/android/key.properties
frontend/android/app/debug/
frontend/android/app/release/
frontend/android/app/profile/
frontend/android/captures/
frontend/android/.idea/

# iOS build artifacts
frontend/ios/Pods/
frontend/ios/.symlinks/
frontend/ios/Flutter/App.framework
frontend/ios/Flutter/Flutter.framework
frontend/ios/Flutter/Flutter.podspec
frontend/ios/Flutter/Generated.xcconfig
frontend/ios/Flutter/app.flx
frontend/ios/Flutter/app.zip
frontend/ios/Flutter/flutter_assets/
frontend/ios/ServiceDefinitions.json
frontend/ios/Runner/GeneratedPluginRegistrant.*

# macOS build
frontend/macos/Flutter/GeneratedPluginRegistrant.swift

# Windows build
frontend/windows/flutter/generated_plugin_registrant.cc
frontend/windows/flutter/generated_plugin_registrant.h
frontend/windows/flutter/generated_plugins.cmake

# Linux build
frontend/linux/flutter/generated_plugin_registrant.cc
frontend/linux/flutter/generated_plugin_registrant.h
frontend/linux/flutter/generated_plugins.cmake

# Web build
frontend/web/

# ─────────────────────────────────────────
# Node.js (if used for any scripts)
# ─────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ─────────────────────────────────────────
# Miscellaneous
# ─────────────────────────────────────────

# Temporary files
*.tmp
*.temp
*.bak
*.swp
*.swo
*~

# Test output files
test_output/
test_results/

# Large data files
*.csv
*.json.gz
*.zip
*.tar.gz

# APK build output (generated — don't push)
*.apk
*.aab
*.ipa